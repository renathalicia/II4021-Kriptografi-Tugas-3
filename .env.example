# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite
DB_TYPE=sqlite
DB_PATH=./db.sqlite3

# Atau PostgreSQL (uncomment untuk production)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kriptografi_db
# DB_USER=postgres
# DB_PASSWORD=your-password

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# OPTIONAL: Logging
# ============================================================================
LOG_LEVEL=info
