FROM node:18-alpine

WORKDIR /app

COPY server/package*.json ./

RUN npm ci --only=production

COPY server ./
COPY jwt-lib /jwt-lib

COPY keys /app/keys

EXPOSE 5001

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:5001/health || exit 1

# Start server
CMD ["node", "server.js"]
